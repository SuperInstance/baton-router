{
  "name": "baton-router",
  "version": "1.0.0",
  "description": "Cloudflare-native event router for inter-agent baton messaging",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute baton-router-db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute baton-router-db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {}
}
